---
// Combined "Informationsquellen & Videos zum Thema" box shown above the
// <NextStep> CTA on every step subpage. Wraps both the external link list
// and the video embeds (sourced from step.moreInformation) into a single
// bordered card. Renders nothing if neither links nor embeds are set.
import PrivacyEmbed from '~/components/blog/PrivacyEmbed.astro';
import type { Step } from '~/data/steps';

type Props = {
  step: Step;
};

const { step } = Astro.props;
const info = step.moreInformation;
const links = info?.links ?? [];
const embeds = info?.embed ?? [];
const hasContent = links.length > 0 || embeds.length > 0;
---

{
  hasContent && (
    <section class="not-prose mx-auto mt-3 mb-2 max-w-3xl rounded-2xl border border-slate-200 bg-white p-5 sm:p-6">
      <h2 class="mb-4 text-base font-semibold text-slate-900">
        Informationsquellen & Videos zum Thema:
      </h2>

      {links.length > 0 && (
        <ul class="space-y-2">
          {links.map((link) => (
            <li class="text-sm leading-relaxed sm:text-base">
              <a
                href={link.url}
                class="text-slate-800 underline underline-offset-2 hover:text-[#C94D54]"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.title}
              </a>
              <span class="text-slate-500"> – {link.source}</span>
            </li>
          ))}
        </ul>
      )}

      {embeds.length > 0 && (
        <div class={`space-y-6 ${links.length > 0 ? 'mt-6' : ''}`}>
          {embeds.map((e) => (
            <PrivacyEmbed
              provider={e.provider}
              embedUrl={e.embedUrl}
              title={e.title}
              directUrl={e.directUrl}
            />
          ))}
        </div>
      )}
    </section>
  )
}
