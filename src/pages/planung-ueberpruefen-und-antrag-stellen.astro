---
// Merged page combining the previous /planung-ueberpruefen/ (step 5) and
// /antrag-stellen/ (step 6) into a single subpage. The two old pages
// remain on disk but are no longer linked from steps.ts.
import Layout from '~/layouts/Layout.astro';
import NextStep from '~/components/widgets/NextStep.astro';
import ContentPage from '~/components/widgets/ContentPage.astro';
import Teaser from '~/components/widgets/Teaser.astro';
import MoreInformation from '~/components/widgets/MoreInformation.astro';
import { getStep } from '~/data/steps';

const step = getStep('7')!;
const keyFacts = ['Punkt 1 - <strong>fett markierter Text</strong>', 'Punkt 2', 'Punkt 3'];
const metadata = {
  title: 'Planung überprüfen & Antrag stellen – Karenz Wizard',
  description:
    'Lasst eure Karenzplanung vor Antragstellung kostenfrei überprüfen — bei der Arbeiterkammer und der ÖGK. Sowie: Infos zur Antragstellung.',
};
---

<Layout {metadata}>
  <ContentPage title={step.title} step={{ number: step.number }}>
    <Teaser step={step} />

    <!-- ===== Inhalt aus /planung-ueberpruefen/ ===== -->
    <h2>Wichtig: Eure Planung überprüfen lassen!</h2>
    <p>
      Nutzt die individuelle Beratung unbedingt bevor ihr einen Antrag abschickt, sodass euch kein
      Geld verloren geht / ihr etwas überseht. Jede Familiensituation ist individuell.
    </p>

    <h3>Beratungsstellen im Überblick</h3>
    <ul>
      <li><a href="/ak-beratung/">AK-Beratung</a></li>
      <li><a href="/oegk-beratung/">ÖGK-Beratung</a></li>
      <li><a href="/sonstige-beratungen/">Sonstige Beratungen</a></li>
      <li><a href="/feministische-beratung/">Feministische Beratung?</a></li>
    </ul>

    <h2>Den Kinderbetreuungsgeld-Antrag stellen - wie läuft das ab?</h2>
    <p>
      Die gute Nachricht zuerst, der Antrag auf Kinderbetreuungsgeld hat nur vier Seiten. 🥳 Du
      kannst den Antrag komfortabel digital ausfüllen. Hier findest du den Antrag auch als
      PDF-Version:
      <ul>
        <li>
          <a
            href="https://www.oegk.at/cdscontent/?contentid=10007.879630&portal=oegkportal"
            class="underline">Anspruch und Antrag - oegk.at</a
          >
        </li>
      </ul>
    </p>
    <p></p>
    <p>
      Tipp: Schau dir den Antrag einmal als PDF an, Unklarheiten kannst du dann in der Beratung
      erfragen.
    </p>

    <h3>Jedes Elternteil reicht einen Antrag ein für seinen Karenzteil</h3>
    <p>
      Wenn du dir das einkommensabhängige Kinderbetreungsgeld mit deiner Partnerin/deinem Partner
      aufteilst, dann reicht ihr zwei Anträge ein: Zuerst das Elternteil, das die erste Karenz nimmt
      - später reicht das zweite Elternteil den zweiten Antrag ein.
    </p>
    <h3>Systemwahl - der erste Antrag legt es fest</h3>
    <p>
      Das Elternteil, das zuerst seinen Karenzteil beantragt, legt das Fördermodell für das Paar
      fest:
    </p>
    <a href="/antraege/kbg_antrag_systemwahl_jaenner_2026.jpg">
      <img
        src="/antraege/kbg_antrag_systemwahl_jaenner_2026.jpg"
        alt="Ausschnitt aus Antrag, Systemwahl"
      />
    </a>
    <p>
      <i
        >Screenshot aus Antrag, Version: „KBGG1 – Jänner 2025“. Der Antrag als PDF sowie das
        erwähnte Informationsblatt KBGG2 kann auf <a
          href="https://www.oegk.at/cdscontent/?contentid=10007.879630&portal=oegkportal"
          class="underline">oegk.at</a
        > heruntergeladen werden.</i
      >
    </p>
  </ContentPage>
  <MoreInformation step={step} />
  <NextStep step={step} />
</Layout>
