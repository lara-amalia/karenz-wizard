---
// /schritte-im-ueberblick/ — "Die Schritte im Überblick"
// Linear vertical stack of numbered step cards. Top-level steps 1–9, with
// 3.1 / 3.2 / 3.3 indented under step 3 to preserve the parent/variant
// relationship.
//
// Title, href and teaser come from src/data/steps.ts (single source of
// truth, also used as the first paragraph on each step subpage). Embed,
// kicker, cta-label and variant remain local to this page.
import Layout from '~/layouts/Layout.astro';
import PrivacyEmbed from '~/components/blog/PrivacyEmbed.astro';
import ContentPage from '~/components/widgets/ContentPage.astro';
import StepsTOC from '~/components/widgets/StepsTOC.astro';
import { steps } from '~/data/steps';

// Titles in steps.ts carry a leading number prefix (e.g. "1. " or "3.1 ") so
// the prefix shows on each subpage's H1. The overview cards already render
// the number in a separate badge, so strip it here to avoid duplication.
const stripNumberPrefix = (title: string) => title.replace(/^\d+(\.\d+)?\.?\s+/, '');

const cards = steps.map((s) => ({
  number: s.number,
  title: stripNumberPrefix(s.title),
  href: s.href,
  // CTA defaults to the subpage with the after-teaser anchor; can be
  // overridden per step via stepCards.ctaLink.
  ctaHref: s.stepCards?.ctaLink ?? `${s.href}#inhalt`,
  teaser: s.teaser,
  embed: s.moreInformation?.embed?.[0],
  kicker: s.stepCards?.kicker,
  ctaLabel: s.stepCards?.ctaLabel ?? 'Mehr erfahren',
  variant: s.stepCards?.variant,
  openInNewTab: s.stepCards?.openInNewTab ?? false,
}));
---

<Layout>
  <ContentPage
    title="Die Schritte im Überblick"
    align="center"
    prose={false}
    showDisclaimer={false}
  >
    <p slot="subtitle" class="text-base leading-relaxed text-slate-600">
      Diese Seite ist eine <strong>„Hilfe zur Selbsthilfe"</strong> für Neu-Väter. Du kannst hier ein
      Gefühl für deine Möglich&shy;keiten bekommen, um mehr als nur 2 Monate in Karenz zu gehen. Du findest
      hier auch Informationen, wie du auf anderen Wegen für dein Kind da sein kannst in den ersten Jahren,
      bspw. durch Eltern-Teilzeit.
    </p>

    <!-- <StepsTOC /> -->

    <ol class="mt-10 list-none space-y-6 p-0" aria-label="Planungsschritte">
      {
        cards.map((step) => (
          <li
            id={`step-${step.number}`}
            data-step-target={step.number}
            class={`scroll-mt-24 ${step.variant === 'sub' ? 'ml-6 sm:ml-12' : ''}`}
          >
            <details
              class={
                'group overflow-hidden rounded-3xl border bg-white shadow-sm transition-shadow duration-200 focus-within:shadow-lg hover:shadow-lg ' +
                (step.variant === 'sub' ? 'border-slate-200/80' : 'border-slate-200/60')
              }
            >
              <summary class="flex cursor-pointer list-none items-start gap-4 px-6 py-6 sm:px-8 sm:py-7 [&::-webkit-details-marker]:hidden">
                <span
                  class={
                    'shrink-0 font-heading font-bold leading-none tabular-nums ' +
                    (step.variant === 'sub'
                      ? 'text-xl text-slate-400'
                      : 'text-3xl text-[#C94D54] sm:text-4xl')
                  }
                  aria-hidden="true"
                >
                  {step.number}
                </span>
                <div class="flex-1">
                  {step.kicker && (
                    <p
                      class="text-xs font-semibold uppercase tracking-wide text-slate-500"
                      set:html={step.kicker}
                    />
                  )}
                  <h2
                    class={
                      'mt-1 font-heading font-bold leading-tight text-slate-900 ' +
                      (step.variant === 'sub' ? 'text-lg sm:text-xl' : 'text-xl sm:text-2xl')
                    }
                    set:html={step.title}
                  />
                </div>
                <span
                  aria-hidden="true"
                  class="ml-2 mt-1 shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-180"
                >
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path
                      fill-rule="evenodd"
                      d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              </summary>

              <div class="flex flex-col gap-4 px-6 pb-6 sm:px-8 sm:pb-7">
                {(Array.isArray(step.teaser) ? step.teaser : [step.teaser]).map((p, i) => (
                  <p
                    class={
                      i === 0
                        ? 'lead leading-relaxed'
                        : 'text-sm leading-relaxed text-slate-600 sm:text-base'
                    }
                    set:html={p}
                  />
                ))}

                <div>
                  <a
                    href={step.ctaHref}
                    target={step.openInNewTab ? '_blank' : undefined}
                    rel={step.openInNewTab ? 'noopener noreferrer' : undefined}
                    class={
                      'inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition sm:text-base ' +
                      (step.variant === 'sub'
                        ? 'border border-[#C94D54] text-[#C94D54] hover:bg-[#C94D54]/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C94D54]'
                        : 'bg-[#C94D54] text-white hover:bg-[#b64048] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C94D54]')
                    }
                  >
                    {step.ctaLabel}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>

                {step.embed && (
                  <PrivacyEmbed
                    provider={step.embed.provider}
                    embedUrl={step.embed.embedUrl}
                    title={step.embed.title}
                    directUrl={step.embed.directUrl}
                  />
                )}
              </div>
            </details>
          </li>
        ))
      }
    </ol>
  </ContentPage>
</Layout>
