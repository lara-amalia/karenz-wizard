---
// Phase 5 finale: eakbg-planer as a hydrated Svelte island.
// The entire page is rendered by EaKbgPlaner.svelte (2270 LOC of Svelte 5
// runes) — mounted with client:load since the page is useless without
// its interactivity.
import Layout from '~/layouts/Layout.astro';
import EaKbgPlaner from '~/lib/components/EaKbgPlaner.svelte';
import NextStep from '~/components/widgets/NextStep.astro';
import StepBreadcrumb from '~/components/widgets/StepBreadcrumb.astro';
import Disclaimer from '~/components/widgets/Disclaimer.astro';
---

<Layout>
  <section class="content min-w-0">
    <div class="mt-10">
      <StepBreadcrumb number="3" />
    </div>
    <div class="mt-4 min-w-0">
      <h1 id="planner-title" class="text-3xl font-semibold text-slate-900">
        eaKBG Planer für Paare
      </h1>
      <Disclaimer />
      <p class="leading-relaxed text-slate-800 mb-6">
        Starte hier mit den minimalen zwei Monaten Väterkarenz beim einkommens&shy;abhängigen
        Kinderbetreuungs&shy;geld. Schau dir Möglichkeiten an, wie du länger in Karenz gehen kannst.
        Entweder indem die Mutter weniger Monate nimmt im ersten Teil - oder indem du als Vater noch
        in "unbezahlte Karenz" gehst nach den 14 Monaten. Eltern-Teilzeit könnte ebenso eine Option
        sein, falls du Anspruch hast².
      </p>
    </div>
    <h2 class="text-2xl font-semibold text-slate-900 mb-2">Karenz interaktiv aufteilen</h2>
    <EaKbgPlaner client:load />

    <aside class="not-prose mx-auto mt-12 mb-4 max-w-3xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">
        Optionale Sub-Schritte
      </p>
      <ul class="space-y-2">
        <li>
          <a
            href="/unbezahlte-karenz/"
            class="flex items-center gap-3 rounded-xl border border-slate-200/60 bg-white px-4 py-3 text-sm transition hover:border-[#C94D54]/40 hover:shadow-sm sm:text-base"
          >
            <span
              class="shrink-0 font-heading font-bold tabular-nums text-slate-400"
              aria-hidden="true">3.1</span
            >
            <span class="text-slate-800">Option: Unbezahlte Karenz</span>
          </a>
        </li>
        <li>
          <a
            href="/elternteilzeit-20-20/"
            class="flex items-center gap-3 rounded-xl border border-slate-200/60 bg-white px-4 py-3 text-sm transition hover:border-[#C94D54]/40 hover:shadow-sm sm:text-base"
          >
            <span
              class="shrink-0 font-heading font-bold tabular-nums text-slate-400"
              aria-hidden="true">3.2</span
            >
            <span class="text-slate-800">Option: Eltern-Teilzeit mit 20h/20h</span>
          </a>
        </li>
        <li>
          <a
            href="/arbeitssuchend-karenz/"
            class="flex items-center gap-3 rounded-xl border border-slate-200/60 bg-white px-4 py-3 text-sm transition hover:border-[#C94D54]/40 hover:shadow-sm sm:text-base"
          >
            <span
              class="shrink-0 font-heading font-bold tabular-nums text-slate-400"
              aria-hidden="true">3.3</span
            >
            <span class="text-slate-800">Arbeitssuchend &amp; "Karenz"?</span>
          </a>
        </li>
      </ul>
    </aside>

    <NextStep
      number="4"
      label="Eure Planung kostenfrei überprüfen lassen"
      href="/planung-ueberpruefen/"
    />
  </section>
</Layout>
