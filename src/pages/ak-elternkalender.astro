---
import Layout from '~/layouts/Layout.astro';
import ContentPage from '~/components/widgets/ContentPage.astro';
import NextStep from '~/components/widgets/NextStep.astro';
import Teaser from '~/components/widgets/Teaser.astro';
import MoreInformation from '~/components/widgets/MoreInformation.astro';
import { getStep } from '~/data/steps';

const step = getStep('1')!;
const metadata = {
  title: 'AK Elternkalender – Karenz Wizard',
  description:
    'Damit ihr keine Fristen verpasst: der Elternkalender der Arbeiterkammer als praktischer Begleiter durch Karenz und Antragsfristen.',
};
---

<Layout {metadata}>
  <ContentPage title={step.title} step={{ number: step.number }} showDisclaimer={false}>
    <Teaser step={step} />
    <p class="text-center">
      <a href="https://elternkalender.arbeiterkammer.at/" target="_blank" rel="noopener noreferrer"
        >Zum AK Elternkalender ↗</a
      >
    </p>
  </ContentPage>
  <MoreInformation step={step} />
  <NextStep step={step} />
</Layout>
