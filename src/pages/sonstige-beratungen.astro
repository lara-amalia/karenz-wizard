---
import Layout from '~/layouts/Layout.astro';
import ContentPage from '~/components/widgets/ContentPage.astro';
---

<Layout>
  <ContentPage title="Sonstige Beratungen & Communities">
    <p>
      Neben der <a href="/ak-beratung/">Arbeiterkammer</a> und der
      <a href="/oegk-beratung/">ÖGK</a> gibt es noch weitere Anlaufstellen, die werdende Eltern rund um
      Karenz, Papamonat und Vaterrolle unterstützen.
    </p>

    <h3>Online-Workshop für werdende Väter (papainfo.at)</h3>
    <ul>
      <li>
        <a href="https://www.papainfo.at/#termine" target="_blank" rel="noopener noreferrer"
          >papainfo.at – Termine &amp; Online-Workshop für werdende Väter</a
        >
      </li>
    </ul>
    <h3>Online-Communities</h3>
    <ul>
      <li>
        Auf reddit finden sich in <a href="https://www.reddit.com/r/FinanzenAT/" target="_blank"
          >r/FinanzenAT</a
        > (oder auch <a href="https://www.reddit.com/r/Austria/" target="_blank">r/Austria</a>) auch
        ab und an Fragen zu Kinderbetreuungsgeld & Co
      </li>
    </ul>
  </ContentPage>
</Layout>
